---
import MainLayout from "../layouts/MainLayout.astro";
import SocialIcons from "../components/SocialIcons.astro";
import HighlightedText from "../components/HighlightedText.astro";
import ProjectsSection from "../components/projects/ProjectsSection.astro";
---

<MainLayout>
    <section
        class="h-[80vh] md:p-10 flex flex-col justify-center gap-4"
        id="hero"
    >
        <h1 class="text-2xl md:text-4xl">
            <HighlightedText>></HighlightedText> Allan_Maciente<HighlightedText
                >.init()</HighlightedText
            >
        </h1>

        <h3 class="text-1xl md:text-2xl">Desenvolvedor</h3>

        <p class="md:max-w-2/3 pt-6">
            Formado pelo programa
            <HighlightedText>Jovem Programador</HighlightedText> (Senac) e atualmente
            graduando em
            <HighlightedText>ADS</HighlightedText> pela Estácio. Gosto de transformar
            problemas em
            <HighlightedText>código</HighlightedText>. Fora da programação,
            curto
            <HighlightedText>basquete</HighlightedText> e ouvir rock.
            <span class="animate-pulse">_</span>
        </p>

        <SocialIcons class="pt-4" />
    </section>
    <section
        class="mim-h-[80vh] md:p-10 flex flex-col justify-center gap-4"
        id="tach_stack"
    >
        <h2 class="text-2xl md:text-3xl">
            <HighlightedText>$</HighlightedText> tech-stack --list
        </h2>
        <p class="mt-2 leading-8">
            <HighlightedText>Node.js</HighlightedText> ·
            <HighlightedText>React</HighlightedText> ·
            <HighlightedText>Astro</HighlightedText> · TypeScript · Tailwind CSS ·
            <br class="hidden md:block" />

            Prisma-ORM · PostgreSQL · Zod · JWT · Docker · Python
        </p>
        <p class="opacity-60">explorando: NestJS · Next.js</p>
    </section>
    <ProjectsSection />
</MainLayout>
