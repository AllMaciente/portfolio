---
import HighlightedText from "../HighlightedText.astro";
import ProjectCard from "./ProjectCard.astro";

export interface Project {
    title: string;
    description: string;
    longDescription?: string;
    github?: string;
    demo?: string;
    tags?: string[];
    status?: "concluído" | "em desenvolvimento" | "arquivado";
    year?: string;
    role?: string;
    highlights?: string[];
    images?: string[];
    githubStats?: boolean;
}

import projectsJson from "../../../public/projects.json";

const projects: Project[] = projectsJson as Project[];
---

<section
    class="mim-h-[80vh] md:p-10 flex flex-col justify-center gap-4"
    id="projects"
>
    <h2 class="text-2xl md:text-3xl">
        <HighlightedText>#</HighlightedText> projetos
    </h2>

    <div class="grid md:grid-cols-2 items-start">
        {projects.map((project, i) => <ProjectCard {...project} index={i} />)}
    </div>
</section>
